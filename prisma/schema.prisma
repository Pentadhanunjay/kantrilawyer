generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("user")
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  couponUsages CouponUsage[]
  orders       Order[]
  purchases    Purchase[]
  sessions     Session[]

  @@map("users")
}

model Coupon {
  id                  Int           @id @default(autoincrement())
  code                String        @unique
  description         String?
  type                String        @default("percentage")
  value               Float
  minOrderAmount      Float         @default(0)
  maxUsage            Int?
  usageCount          Int           @default(0)
  maxUsagePerUser     Int           @default(1)
  allowedTypes        String?       // JSON: ["courses", "ebooks", "books", "classes"]
  allowedUniversities String?
  allowedSemesters    String?
  allowedStates       String?
  allowedCourseIds    String?
  allowedEbookIds     String?
  allowedBookIds      String?
  allowedClassIds     String?
  expiresAt           DateTime?
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  usages              CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id             Int      @id @default(autoincrement())
  couponId       Int
  userId         String
  courseId       Int?
  ebookId        Int?
  bookId         Int?
  classId        Int?
  discountAmount Float
  originalAmount Float
  usedAt         DateTime @default(now())
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coupon_usages")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Course {
  id            Int        @id @default(autoincrement())
  title         String
  description   String
  category      String
  price         Float
  originalPrice Float      @default(0)
  rating        String     @default("4.9")
  duration      String?
  videoUrl      String?
  image         String?
  sales         Int        @default(0)
  isPublished   Boolean    @default(true)
  university    String?    @default("Osmania University")
  semester      String?    @default("Sem - I")
  state         String?    @default("Telangana")
  curriculum    Json?
  outcomes      Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  purchases     Purchase[]

  @@map("courses")
}

model Ebook {
  id            Int        @id @default(autoincrement())
  title         String
  description   String
  category      String
  price         Float
  originalPrice Float      @default(0)
  rating        String     @default("4.9")
  image         String?
  fileUrl       String?
  sales         Int        @default(0)
  isPublished   Boolean    @default(true)
  university    String?
  semester      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  purchases     Purchase[]

  @@map("ebooks")
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  category      String
  price         Float
  originalPrice Float    @default(0)
  rating        String   @default("4.8")
  image         String?
  stock         Int      @default(100)
  sales         Int      @default(0)
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@map("books")
}

model LiveClass {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  date        String
  time        String
  duration    String?
  host        String     @default("Uday Kantri")
  price       Float      @default(0)
  meetLink    String?
  status      String     @default("scheduled")
  category    String     @default("LLB")
  isPublished Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  purchases   Purchase[]

  @@map("live_classes")
}

model Purchase {
  id         String     @id @default(cuid())
  userId     String
  type       String
  courseId   Int?
  ebookId    Int?
  classId    Int?
  amount     Float
  paymentId  String?
  status     String     @default("completed")
  expiryDate DateTime?
  createdAt  DateTime   @default(now())
  liveClass  LiveClass? @relation(fields: [classId], references: [id])
  course     Course?    @relation(fields: [courseId], references: [id])
  ebook      Ebook?     @relation(fields: [ebookId], references: [id])
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  bookId    Int
  quantity  Int      @default(1)
  amount    Float
  paymentId String?
  status    String   @default("pending")
  address   String?
  city      String?
  state     String?
  pincode   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  phone     String?

  @@map("contact_messages")
}
